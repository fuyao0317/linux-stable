/dts-v1/;
#include "sun8i-r40-feta40i.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "Cyg A40i SOC";
	compatible = "forlinx,oka40i-c", "forlinx,feta40i-c", "allwinner,sun8i-r40";

	aliases {
		ethernet0 = &gmac;
		serial0 = &uart0;
		serial2 = &uart2;
		serial3 = &uart3;
		serial4 = &uart4;
		serial5 = &uart5; /* RS485 */
		serial7 = &uart7;
		mmc0 = &mmc0;
		mmc1 = &mmc1;
		mmc2 = &mmc2;
		mmc3 = &mmc3;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	hdmi-connector {
		compatible = "hdmi-connector";
		type = "a";

		port {
			hdmi_con_in: endpoint {
				remote-endpoint = <&hdmi_out_con>;
			};
		};
	};

	leds {
		compatible = "gpio-leds";

		led-6 {
			gpios = <&pio 8 15 GPIO_ACTIVE_LOW>; /* PI15 */
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_STATUS;
		};

		led-5 { /* this is how the leds are labeled on the board */
			gpios = <&pio 1 11 GPIO_ACTIVE_LOW>; /* PB11 */
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_HEARTBEAT;
			linux,default-trigger = "heartbeat";
		};
	};

	reg_vcc5v0: vcc5v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
	};

	wifi_pwrseq: wifi_pwrseq {
		compatible = "mmc-pwrseq-simple";
		reset-gpios = <&pio 4 8 GPIO_ACTIVE_LOW>; // PE08 WIFI_EN
		clocks = <&ccu CLK_OUTA>;
		clock-names = "ext_clock";
	};

	beep: beep {
		compatible = "gpio-beeper";
		gpios = <&pio 1 3 GPIO_ACTIVE_HIGH>;
	};

	lvds_backlight: lvds-backlight {
		compatible = "pwm-backlight";
		pwms = <&pwm 0 5000000 0>;
		pwm-names = "backlight";
		enable-gpios = <&pio 1 4 GPIO_ACTIVE_HIGH>;
		brightness-levels = <0 100>;
		num-interpolated-steps = <100>;
		default-brightness-level = <80>;
	};

	watchdog_gpio:watchdog-gpio {
		/* SGM823 */
		compatible = "linux,wdt-gpio";
		gpios = <&pio 3 10 GPIO_ACTIVE_LOW>;
		hw_algo = "toggle";
		hw_margin_ms = <1600>;
		//always-running = "true";
	};
	
	em4095rfid:em4095RFID {
		compatible = "em4095RFID";
		pinctrl-names = "default";
		pinctrl-0 = <&rfid_pins_out>,<&rfid_pins_in>;
		shd = <&pio 3 11 GPIO_ACTIVE_HIGH>;
		demod_out = <&pio 3 12 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};
};
&pio {
	rfid_pins_out:rfid-pins-out{
		pins = "PD11";
		function = "gpio_out";
	};
	rfid_pins_in:rfid-pins-in{
		pins =  "PD12";
		function = "gpio_in";
	};
};
&ahci {
	ahci-supply = <&reg_dldo4>;
	phy-supply = <&reg_eldo2>;
	status = "okay";
};

&de {
	status = "okay";
};

&ehci0 {
	status = "okay";
};

&ehci1 {
	status = "okay";
};

&ehci2 {
	status = "okay";
};

&gmac {
	pinctrl-names = "default";
	pinctrl-0 = <&gmac_rgmii_pins>;
	phy-handle = <&phy1>;
	phy-mode = "rgmii-id";
	phy-supply = <&reg_dcdc1>;
	allwinner,tx-delay-ps = <300>;
	allwinner,rx-delay-ps = <200>;
	status = "okay";
};

&gmac_mdio {
	phy1: ethernet-phy@2 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <2>;
	};
};

&hdmi {
	status = "okay";
};

&hdmi_out {
	hdmi_out_con: endpoint {
		remote-endpoint = <&hdmi_con_in>;
	};
};

&can0 {
	pinctrl-names = "default";
	pinctrl-0 = <&can_ph_pins>;
	/* status = "okay"; */
};

&i2c1 {
	status = "okay";
	
	fm17550:fm17550@28{
 		compatible = "fm17550";
	 	reg = <0x28>;
	};
};

&i2c2 {
	status = "okay";
	
	rtc_3078:rtc-3078@32{
 		compatible = "whwave,sd3078";
	 	reg = <0x32>;
	};
	
	eeprom_24c04:eeprom-24c04@50 {
		compatible = "atmel,24c512";
		pagesize = <128>;
		reg = <0x50>;
	};
};
&i2c3 {
	status = "okay";
};
&i2c4 {
	status = "okay";
};
&mmc0 {
	vmmc-supply = <&reg_dcdc1>;
	vqmmc-supply = <&reg_dcdc1>;
	bus-width = <4>;
	cd-gpios = <&pio 8 11 GPIO_ACTIVE_LOW>; // PI11
	status = "okay";
};
&mmc1 {
	mmc-pwrseq = <&wifi_pwrseq>;
	bus-width = <4>;
	vmmc-supply = <&reg_dldo1>;
	vqmmc-supply = <&reg_dldo1>;
	non-removable;
	wakeup-source;
	keep-power-in-suspend;
	status = "okay";

	brcmf: wifi@1 {
		reg = <1>;
		compatible = "brcm,bcm4329-fmac";
		interrupt-parent = <&pio>;
		interrupts = <7 1 IRQ_TYPE_LEVEL_LOW>; /* PH1 WL_WAKE_UP */
		interrupt-names = "host-wake";
	};
};
&mmc3 {
	vmmc-supply = <&reg_dcdc1>;
	vqmmc-supply = <&reg_dcdc1>;
	bus-width = <4>;
	cd-gpios = <&pio 8 10 GPIO_ACTIVE_LOW>; // PI10
	status = "disabled";
};

&ohci0 {
	status = "okay";
};

&ohci1 {
	status = "okay";
};

&ohci2 {
	status = "okay";
};

&reg_dc1sw {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	regulator-name = "vcc-lcd";
};

&reg_dldo2 {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	regulator-name = "vcc-wifi";
};

&tcon_tv0 {
	status = "okay";
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pb_pins>;
	status = "okay";
};

&uart2 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart2_pi_pins>, <&uart2_rts_cts_pi_pins>;
	uart-has-rtscts;
	status = "okay";
};

&uart3 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart3_pg_pins>, <&uart3_rts_cts_pg_pins>;
	uart-has-rtscts;
	status = "okay";
	bluetooth {
		compatible = "brcm,bcm43438-bt";
		clocks = <&ccu CLK_OUTA>;
		clock-names = "lpo";
		vbat-supply = <&reg_dldo1>;
		vddio-supply = <&reg_dldo1>;
		device-wakeup-gpios = <&pio 0 17 GPIO_ACTIVE_HIGH>; /* PA17 */
		host-wakeup-gpios = <&pio 8 13 GPIO_ACTIVE_HIGH>; /* PI13 */
		shutdown-gpios = <&pio 7 12 GPIO_ACTIVE_HIGH>; /* PH12 */
		
		max-speed = <115200>;
	};
};

&uart4 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart4_pg_pins>;
	status = "okay";
};

&uart5 { /* RS485 */
	pinctrl-names = "default";
	pinctrl-0 = <&uart5_ph_pins>;
	status = "okay";
};

&uart7 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart7_pi_pins>;
	status = "okay";
};

&usbphy {
	usb_vbus-supply = <&reg_vcc5v0>;
	usb1_vbus-supply = <&reg_vcc5v0>;
	usb2_vbus-supply = <&reg_vcc5v0>;
	status = "okay";
};

&usb_otg {
	dr_mode = "host";
	status = "okay";
};

&emac {
	pinctrl-0 = <&emac_ph_pins>;
	pinctrl-names = "default";
	phy-handle = <&phy2>;
	status = "okay";
};

&emac_mdio {
	status = "okay";
	reset-gpios = <&pio 1 9 GPIO_ACTIVE_LOW>; // PB9 MII_RESET
	reset-delay-us = <10000>;
	phy2: ethernet-phy@3 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <3>;
	};
};

&emac_sram {
	status = "okay";
};

&panel_lvds {
	pinctrl-names = "default";
	pinctrl-0 = <&lvds0_pd_pins>;
	width-mm = <246>;
	height-mm = <184>;
	data-mapping = "vesa-24";
	backlight = <&lvds_backlight>;

	panel-timing {
		clock-frequency = <65000000>;
		hactive = <1024>;
		vactive = <768>;
		hback-porch = <220>;
		hfront-porch = <40>;
		vback-porch = <21>;
		vfront-porch = <7>;
		hsync-len = <60>;
		vsync-len = <10>;
	};

};

&codec {
	allwinner,audio-routing =
		"Headphone", "Phoneout";
	allwinner,codec-analog-controls = <&codec_analog>;
	allwinner,pa-gpios = <&pio 1 5 GPIO_ACTIVE_LOW>; // PB5 SPK SHUTDOWN
	status = "okay";
};

&codec_analog {
	status = "okay";
};

&pwm {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm_ch0_pin>,<&pwm_ch1_pin>;
	status = "okay";
};

&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi0_pc_pins>, <&spi0_cs0_pc_pin>;
	status = "okay";

	spidev@0 {
		compatible = "cyg,spi-dev";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};
};
&spi2 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi2_pi_pins>,<&spi2_cs0_pi_pin>,<&spi2_cs1_pi_pin>;
	status = "okay";

	can@0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "microchip,mcp2515";
		reg = <0>;
		mode=<0>;
		clocks = <&osc8M>;
		interrupt-parent = <&pio>;
		interrupts = <7 0 IRQ_TYPE_EDGE_FALLING>; /* PH0 */
		spi-max-frequency = <10000000>;
	};
	can@1 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "microchip,mcp2515";
		reg = <1>;
		mode=<0>;
		clocks = <&osc8M>;
		interrupt-parent = <&pio>;
		interrupts = <7 4 IRQ_TYPE_EDGE_FALLING>; /* PH4*/
		spi-max-frequency = <10000000>;
	};

};
